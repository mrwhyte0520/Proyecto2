@model List<Departamento>
@{
    ViewData["Title"] = "Departamentos";
}

<a asp-controller="Home" asp-action="Index" class="btn btn-secondary mb-3">&larr; Volver</a>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Departamentos</h1>
    @if (User.IsInRole(Roles.Admin) || User.IsInRole(Roles.RRHH))
    {
        <a asp-action="Create" class="btn btn-primary">Nuevo departamento</a>
    }
</div>

@if (TempData["Mensaje"] is not null)
{
    <div class="alert alert-success">@TempData["Mensaje"]</div>
}
@if (TempData["Error"] is not null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<table class="table table-striped align-middle">
    <thead>
        <tr>
            <th>Nombre</th>
            <th>Descripción</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var departamento in Model)
        {
            <tr>
                <td>@departamento.Nombre</td>
                <td>@departamento.Descripcion</td>
                <td class="d-flex gap-2">
                    @if (User.IsInRole(Roles.Admin) || User.IsInRole(Roles.RRHH))
                    {
                        <a asp-action="Edit" asp-route-id="@departamento.Id" class="btn btn-sm btn-outline-primary">Editar</a>
                    }
                    @if (User.IsInRole(Roles.Admin))
                    {
                        <form asp-action="Delete" asp-route-id="@departamento.Id" method="post" onsubmit="return confirm('¿Eliminar este departamento?');">
                            <button type="submit" class="btn btn-sm btn-outline-danger">Eliminar</button>
                        </form>
                    }
                </td>
            </tr>
        }
        @if (!Model.Any())
        {
            <tr><td colspan="3" class="text-center text-muted">No hay departamentos registrados.</td></tr>
        }
    </tbody>
</table>
