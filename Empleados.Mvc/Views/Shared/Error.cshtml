@model ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<div class="text-center">
    <h1 class="text-danger">Ha ocurrido un error</h1>
    <p class="lead">No pudimos procesar su solicitud. Intente nuevamente más tarde.</p>

    @if (Model.ShowRequestId)
    {
        <p class="text-muted">
            <strong>Id. de solicitud:</strong> <code>@Model.RequestId</code>
        </p>
    }

    <a asp-controller="Home" asp-action="Index" class="btn btn-primary">Volver al inicio</a>
</div>
